---
/**
 * @txid/ui — Toast Notification Container
 *
 * 사용법:
 *   <Toast />
 *   그런 다음 JS에서: import { showToast } from '@txid/ui/utils/toast.js';
 *   showToast('저장되었습니다', 'success');
 */
---

<div
  id="txid-toast-container"
  aria-live="assertive"
  aria-atomic="true"
  role="status"
></div>

<style>
  #txid-toast-container {
    position: fixed;
    top: 16px;
    right: 16px;
    z-index: 10000;
    display: flex;
    flex-direction: column;
    gap: 8px;
    pointer-events: none;
    max-width: 380px;
    width: 100%;
  }

  /* Toast item styles (injected dynamically by toast.js) */
  #txid-toast-container :global(.txid-toast) {
    pointer-events: auto;
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 12px 16px;
    border-radius: var(--radius, 8px);
    font-family: var(--font-ko, sans-serif);
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--text1, #e6edf3);
    background: var(--bg2, #161b22);
    border: 1px solid var(--border, #30363d);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
    animation: txid-toast-in 0.3s ease-out forwards;
    position: relative;
    overflow: hidden;
    word-break: break-word;
  }

  #txid-toast-container :global(.txid-toast--removing) {
    animation: txid-toast-out 0.25s ease-in forwards;
  }

  /* Type variants — left accent bar */
  #txid-toast-container :global(.txid-toast)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    border-radius: var(--radius, 8px) 0 0 var(--radius, 8px);
  }

  #txid-toast-container :global(.txid-toast--success)::before {
    background: var(--green, #3fb950);
  }
  #txid-toast-container :global(.txid-toast--error)::before {
    background: var(--red, #f85149);
  }
  #txid-toast-container :global(.txid-toast--info)::before {
    background: var(--blue, #58a6ff);
  }
  #txid-toast-container :global(.txid-toast--warning)::before {
    background: var(--yellow, #d29922);
  }

  /* Icon color per type */
  #txid-toast-container :global(.txid-toast--success .txid-toast-icon) {
    color: var(--green, #3fb950);
  }
  #txid-toast-container :global(.txid-toast--error .txid-toast-icon) {
    color: var(--red, #f85149);
  }
  #txid-toast-container :global(.txid-toast--info .txid-toast-icon) {
    color: var(--blue, #58a6ff);
  }
  #txid-toast-container :global(.txid-toast--warning .txid-toast-icon) {
    color: var(--yellow, #d29922);
  }

  /* Icon */
  #txid-toast-container :global(.txid-toast-icon) {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    margin-top: 1px;
  }

  /* Message */
  #txid-toast-container :global(.txid-toast-msg) {
    flex: 1;
    min-width: 0;
  }

  /* Dismiss button */
  #txid-toast-container :global(.txid-toast-close) {
    flex-shrink: 0;
    background: none;
    border: none;
    color: var(--text3, #6e7681);
    cursor: pointer;
    padding: 2px;
    line-height: 1;
    font-size: 1rem;
    transition: color 0.15s;
    margin-top: -2px;
  }
  #txid-toast-container :global(.txid-toast-close:hover) {
    color: var(--text1, #e6edf3);
  }

  /* Progress bar */
  #txid-toast-container :global(.txid-toast-progress) {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 2px;
    border-radius: 0 0 0 var(--radius, 8px);
    animation: txid-toast-progress linear forwards;
    opacity: 0.6;
  }
  #txid-toast-container :global(.txid-toast--success .txid-toast-progress) {
    background: var(--green, #3fb950);
  }
  #txid-toast-container :global(.txid-toast--error .txid-toast-progress) {
    background: var(--red, #f85149);
  }
  #txid-toast-container :global(.txid-toast--info .txid-toast-progress) {
    background: var(--blue, #58a6ff);
  }
  #txid-toast-container :global(.txid-toast--warning .txid-toast-progress) {
    background: var(--yellow, #d29922);
  }

  /* Animations */
  @keyframes txid-toast-in {
    from {
      opacity: 0;
      transform: translateX(100%);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes txid-toast-out {
    from {
      opacity: 1;
      transform: translateX(0);
    }
    to {
      opacity: 0;
      transform: translateX(100%);
    }
  }

  @keyframes txid-toast-progress {
    from {
      width: 100%;
    }
    to {
      width: 0%;
    }
  }

  /* Responsive — 모바일에서는 전체 너비 */
  @media (max-width: 480px) {
    #txid-toast-container {
      top: 8px;
      right: 8px;
      left: 8px;
      max-width: none;
    }
  }
</style>
