---
// Root index — browser language detection with JS fallback
---

<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="robots" content="noindex">
  <link rel="canonical" href="https://tx.txid.uk/en/">
  <script is:inline>
    (function() {
      var saved = null;
      try { saved = localStorage.getItem('lang'); } catch(e) {}
      var lang = saved || (navigator.language || navigator.userLanguage || 'en').slice(0, 2);
      var supported = { ko: '/ko/', en: '/en/', ja: '/ja/' };
      window.location.replace(supported[lang] || '/en/');
    })();
  </script>
  <meta http-equiv="refresh" content="0;url=/en/">
  <title>Redirecting...</title>
</head>
<body>
  <p>Redirecting to <a href="/en/">Bitcoin TX Builder</a>...</p>
</body>
</html>
